<header class="site-header">
  <div class="container header-row">
    <a href="/" class="brand">
      <img class="brand-mark" src="/assets/images/brand-mark.png" alt="" width="44" height="44">
      <span class="brand-text">
        <strong>UD Marketing Tools</strong>
        <small>SEO, content, and campaign utilities</small>
      </span>
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="site-nav"
      aria-label="Open menu"
      data-nav-toggle
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="nav" id="site-nav" aria-label="Main navigation" data-nav>
      <a href="/" class="{{ 'active' if page.url == '/' else '' }}">Home</a>
      <a href="/tools/" class="{{ 'active' if page.url == '/tools/' else ('active' if '/tools/' in page.url else '') }}">Tools</a>
      <a href="/articles/" class="{{ 'active' if page.url == '/articles/' else ('active' if '/articles/' in page.url else '') }}">Articles</a>
      <a href="/about/" class="{{ 'active' if page.url == '/about/' else '' }}">About</a>
      <a href="/contact/" class="{{ 'active' if page.url == '/contact/' else '' }}">Contact</a>
    </nav>
  </div>
</header>

<script>
  (function () {
    const button = document.querySelector("[data-nav-toggle]");
    const nav = document.querySelector("[data-nav]");
    if (!button || !nav) return;

    button.addEventListener("click", function () {
      const isOpen = nav.classList.toggle("is-open");
      button.setAttribute("aria-expanded", isOpen ? "true" : "false");
      button.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu");
    });
  })();
</script>
