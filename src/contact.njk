<section class="page-hero">
  <div class="container">
    <span class="eyebrow">Contact</span>
    <h1>Get in touch.</h1>
    <p>
      Use the contact form to send questions, feedback, or suggestions related to tools, articles, or the project itself.
    </p>
  </div>
</section>

<section class="section-tight">
  <div class="container">
    <div class="card card-pad">
      <h2 class="section-title">Contact form</h2>
      <p class="section-desc">
        This form is connected to Formspree for static site submission handling.
      </p>

      <form action="https://formspree.io/f/xykvdaja" method="POST">
        <div class="form-group">
          <label for="name">Name</label>
          <input id="name" name="name" type="text" class="tool-input">
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" class="tool-input">
        </div>

        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" class="tool-input" rows="6"></textarea>
        </div>

        <div class="hero-actions" style="margin-bottom:0;">
          <button type="submit" class="btn btn-primary">Send Message</button>
        </div>
      </form>
    </div>
  </div>
</section>