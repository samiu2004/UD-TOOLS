---
pagination:
  data: articles
  size: 1
  alias: article
permalink: "/articles/{{ article.slug }}/index.html"
layout: base.njk
eleventyComputed:
  title: "{{ article.seoTitle or article.title }}"
  description: "{{ article.description }}"
---

<section class="page-hero page-hero-compact">
  <div class="container">
    <article class="article-page">
      <header class="article-header">
        <div class="article-header-top">
          <span class="feature-tag">Article</span>
        </div>

        <h1>{{ article.title }}</h1>

        <p class="article-description">{{ article.description }}</p>

        <div class="article-byline">
          <span>By <strong>{{ site.author.name }}</strong></span>
          <span class="article-byline-separator" aria-hidden="true">&bull;</span>
          <time datetime="{{ article.date }}">Published {{ article.date | displayDate }}</time>
        </div>
      </header>

      <div class="article-content">
        {{ article.content | safe }}
      </div>

      {% if article.relatedArticles %}
      <section class="article-related">
        <div class="article-related-head">
          <h2>Related articles</h2>
          <p>Continue with practical guides that support this topic.</p>
        </div>

        <div class="article-related-grid">
          {% for slug in article.relatedArticles %}
            {% for related in articles %}
              {% if related.slug == slug %}
              <article class="feature-card article-card article-card-archive article-card-related">
                <div class="feature-top">
                  <span class="feature-tag">Article</span>
                  <time class="feature-meta" datetime="{{ related.date }}">{{ related.date | displayDate }}</time>
                </div>

                <div class="feature-body">
                  <h3>{{ related.title }}</h3>
                  <p>{{ related.description }}</p>
                </div>

                <div class="feature-bottom">
                  <a class="btn btn-secondary btn-sm" href="/articles/{{ related.slug }}/">Read article</a>
                </div>
              </article>
              {% endif %}
            {% endfor %}
          {% endfor %}
        </div>
      </section>
      {% endif %}
    </article>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ article.title | dump | safe }},
  "description": {{ article.description | dump | safe }},
  "datePublished": {{ article.date | dump | safe }},
  "dateModified": {{ (article.modified or article.date) | dump | safe }},
  "author": {
    "@type": "Person",
    "name": {{ site.author.name | dump | safe }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ site.name | dump | safe }},
    "url": {{ site.url | dump | safe }}
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ site.url }}/articles/{{ article.slug }}/"
  },
  "image": "{{ site.url }}{{ site.defaultOgImage }}"
}
</script>

{% if article.faq %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in article.faq %}
    {
      "@type": "Question",
      "name": {{ item.question | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ item.answer | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}

