---
pagination:
  data: articles
  size: 1
  alias: article
permalink: "/articles/{{ article.slug }}/index.html"
layout: base.njk
eleventyComputed:
  title: "{{ article.seoTitle or article.title }}"
  description: "{{ article.description }}"
---
{% set articleOutline = article.content | articleOutline %}
{% set articleMarkup = article.content | articleBody %}
{% set articleMinutes = article.content | readingTime %}

{% if "utm" in article.slug or "tracking-url" in article.slug or "campaign-url" in article.slug %}
  {% set relatedToolUrl = "/tools/utm-builder/" %}
  {% set relatedToolName = "UTM Builder" %}
{% elif "keyword-density" in article.slug or "keywords-naturally" in article.slug %}
  {% set relatedToolUrl = "/tools/keyword-density-checker/" %}
  {% set relatedToolName = "Keyword Density Checker" %}
{% elif "roas" in article.slug %}
  {% set relatedToolUrl = "/tools/cpc-roas-calculator/" %}
  {% set relatedToolName = "ROAS Calculator" %}
{% elif "meta" in article.slug or "serp" in article.slug %}
  {% set relatedToolUrl = "/tools/meta-tag-generator/" %}
  {% set relatedToolName = "Meta Tag Generator" %}
{% else %}
  {% set relatedToolUrl = "/tools/readability-checker/" %}
  {% set relatedToolName = "Readability Checker" %}
{% endif %}

<section class="page-hero page-hero-compact">
  <div class="container">
    <article class="article-page">
      <header class="article-header">
        <div class="article-header-top">
          <span class="feature-tag">Article</span>
        </div>

        <h1>{{ article.title }}</h1>

        <p class="article-description">{{ article.description }}</p>

        <div class="article-byline">
          <span>By <strong>{{ site.author.name }}</strong></span>
          <span class="article-byline-separator" aria-hidden="true">&bull;</span>
          <time datetime="{{ article.date }}">Published {{ article.date | displayDate }}</time>
          <span class="article-byline-separator" aria-hidden="true">&bull;</span>
          <span>{{ articleMinutes }} min read</span>
        </div>
      </header>

      {% if article.image %}
      <figure class="article-hero-image">
        <img src="{{ article.image }}" alt="{{ article.imageAlt or article.title }}" width="1200" height="630" fetchpriority="high">
      </figure>
      {% endif %}

      {% if articleOutline | length %}
      <details class="article-toc article-toc-mobile">
        <summary>Table of contents</summary>
        <ol>
          {% for heading in articleOutline %}
          <li class="toc-{{ heading.level }}"><a href="#{{ heading.id }}">{{ heading.text }}</a></li>
          {% endfor %}
        </ol>
      </details>
      {% endif %}

      <div class="article-reading-layout">
        {% if articleOutline | length %}
        <aside class="article-toc article-toc-desktop">
          <p class="article-toc-title">On this page</p>
          <nav aria-label="Table of contents">
            <ol>
              {% for heading in articleOutline %}
              <li class="toc-{{ heading.level }}"><a href="#{{ heading.id }}">{{ heading.text }}</a></li>
              {% endfor %}
            </ol>
          </nav>
        </aside>
        {% endif %}

        <div class="article-main-column">
          <div class="article-content">
            {{ articleMarkup | safe }}
          </div>

          <aside class="article-tool-cta">
            <div>
              <span class="mini-label">Put this into practice</span>
              <h2>Continue with the free {{ relatedToolName }}.</h2>
              <p>Open the browser-based tool and apply the steps from this guide without creating an account.</p>
            </div>
            <a class="btn btn-accent" href="{{ relatedToolUrl }}">Open {{ relatedToolName }}</a>
          </aside>
        </div>
      </div>

      {% if article.relatedArticles %}
      <section class="article-related">
        <div class="article-related-head">
          <h2>Related articles</h2>
          <p>Continue with practical guides that support this topic.</p>
        </div>

        <div class="article-related-grid">
          {% for slug in article.relatedArticles %}
            {% for related in articles %}
              {% if related.slug == slug %}
              <article class="feature-card article-card article-card-archive article-card-related">
                <div class="feature-top">
                  <span class="article-card-kind">Related guide</span>
                  <time class="feature-meta" datetime="{{ related.date }}">{{ related.date | displayDate }}</time>
                </div>

                <div class="feature-body">
                  <h3>{{ related.title }}</h3>
                  <p>{{ related.description }}</p>
                </div>

                <div class="feature-bottom">
                  <span class="article-card-author">By {{ site.author.name }}</span>
                  <a class="article-read-link" href="/articles/{{ related.slug }}/">Read guide <span aria-hidden="true">&rarr;</span></a>
                </div>
              </article>
              {% endif %}
            {% endfor %}
          {% endfor %}
        </div>
      </section>
      {% endif %}
    </article>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ article.title | dump | safe }},
  "description": {{ article.description | dump | safe }},
  "datePublished": {{ article.date | dump | safe }},
  "dateModified": {{ (article.modified or article.date) | dump | safe }},
  "author": {
    "@type": "Person",
    "name": {{ site.author.name | dump | safe }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ site.name | dump | safe }},
    "url": {{ site.url | dump | safe }}
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ site.url }}/articles/{{ article.slug }}/"
  },
  "image": "{{ site.url }}{{ article.image or site.defaultOgImage }}"
}
</script>

{% if article.faq %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in article.faq %}
    {
      "@type": "Question",
      "name": {{ item.question | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ item.answer | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}

