<section id="all-tools" class="section tools-directory-section">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">All Tools</span>
      <h2 class="section-title">Choose the job you need to finish.</h2>
      <p class="section-desc">
        Each tool has a focused interface, a clean URL, and supporting guidance so visitors can act quickly.
      </p>
    </div>

    <div class="tool-filter-bar" aria-label="Filter tools by category" data-tool-filters>
      <button class="is-active" type="button" data-tool-filter="all">All tools</button>
      <button type="button" data-tool-filter="writing">Writing</button>
      <button type="button" data-tool-filter="seo">SEO</button>
      <button type="button" data-tool-filter="metadata">Metadata</button>
      <button type="button" data-tool-filter="campaign">Campaigns</button>
      <button type="button" data-tool-filter="utility">QR utilities</button>
    </div>
    <p class="tool-filter-status" aria-live="polite" data-tool-status>{{ tools | length }} tools available</p>

    <div class="tool-directory-grid" data-tool-grid>
      {% for tool in tools %}
        {{ toolCard(tool) }}
      {% endfor %}
    </div>
  </div>
</section>

<script>
  (function () {
    const searchForm = document.querySelector("[data-tool-finder]");
    const searchInput = document.querySelector("[data-tool-search]");
    const filterBar = document.querySelector("[data-tool-filters]");
    const cards = Array.from(document.querySelectorAll("[data-tool-card]"));
    const status = document.querySelector("[data-tool-status]");
    if (!searchForm || !searchInput || !filterBar || !cards.length || !status) return;

    let activeFilter = "all";

    function updateTools() {
      const query = searchInput.value.trim().toLowerCase();
      let visible = 0;

      cards.forEach(function (card) {
        const matchesCategory = activeFilter === "all" || card.dataset.toolCategory === activeFilter;
        const matchesSearch = !query || card.dataset.toolSearchText.toLowerCase().includes(query);
        const shouldShow = matchesCategory && matchesSearch;
        card.hidden = !shouldShow;
        if (shouldShow) visible += 1;
      });

      status.textContent = visible === 1 ? "1 tool available" : visible + " tools available";
    }

    filterBar.addEventListener("click", function (event) {
      const button = event.target.closest("[data-tool-filter]");
      if (!button) return;
      activeFilter = button.dataset.toolFilter;
      filterBar.querySelectorAll("button").forEach(function (item) {
        item.classList.toggle("is-active", item === button);
      });
      updateTools();
    });

    searchInput.addEventListener("input", updateTools);
    searchForm.addEventListener("submit", function (event) {
      event.preventDefault();
      updateTools();
      document.querySelector("#all-tools").scrollIntoView({ behavior: "smooth" });
    });
  })();
</script>

