---
layout: base.njk
title: Free Marketing Tools
description: Explore free SEO, writing, campaign, QR, and marketing utility tools on UD Marketing Tools.
permalink: /tools/
---
<style>
  .tools-hero-clean { padding-bottom: 18px; }
  .tools-hero-clean .tools-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(370px, 0.78fr);
    gap: 56px;
    align-items: center;
  }
  .tools-hero-clean .tools-hero-copy { max-width: 690px; }
  .tools-hero-clean .tools-hero-copy h1 { max-width: 650px; }
  .tools-hero-clean .tools-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 26px;
  }
  .tools-hero-clean .tools-quick-panel {
    overflow: hidden;
    border: 1px solid rgba(24, 34, 48, 0.12);
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.09);
  }
  .tools-hero-clean .tools-quick-head {
    padding: 18px 20px 14px;
    border-bottom: 1px solid rgba(24, 34, 48, 0.09);
  }
  .tools-hero-clean .tools-quick-head strong,
  .tools-hero-clean .tools-quick-head span { display: block; }
  .tools-hero-clean .tools-quick-head strong { color: #111827; font-size: 1rem; }
  .tools-hero-clean .tools-quick-head span { margin-top: 3px; color: #64748b; font-size: 0.82rem; }
  .tools-hero-clean .tools-quick-list { display: grid; }
  .tools-hero-clean .tools-quick-item {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 14px;
    align-items: center;
    padding: 15px 20px;
    border-bottom: 1px solid rgba(24, 34, 48, 0.08);
    color: #111827;
    text-decoration: none;
    transition: background-color 180ms ease;
  }
  .tools-hero-clean .tools-quick-item:hover { background: #f4f7fa; }
  .tools-hero-clean .tools-quick-item strong,
  .tools-hero-clean .tools-quick-item small { display: block; }
  .tools-hero-clean .tools-quick-item strong { font-size: 0.94rem; }
  .tools-hero-clean .tools-quick-item small { margin-top: 3px; color: #64748b; font-size: 0.78rem; }
  .tools-hero-clean .tools-quick-item em { color: #0f766e; font-size: 0.82rem; font-style: normal; font-weight: 900; }
  .tools-hero-clean .tools-quick-summary {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    background: #111827;
    color: #fff;
  }
  .tools-hero-clean .tools-quick-summary span {
    padding: 12px 8px;
    border-right: 1px solid rgba(255, 255, 255, 0.13);
    text-align: center;
    font-size: 0.74rem;
    font-weight: 800;
  }
  .tools-hero-clean .tools-quick-summary span:last-child { border-right: 0; }
  .tools-directory-section { padding-top: 34px; }
  @media (max-width: 1024px) {
    .tools-hero-clean .tools-hero-grid { grid-template-columns: 1fr; gap: 30px; }
    .tools-hero-clean .tools-quick-panel { max-width: 680px; }
  }
  @media (max-width: 760px) {
    .tools-hero-clean .tools-hero-actions .btn { width: 100%; }
    .tools-hero-clean .tools-quick-item { padding: 14px 16px; }
    .tools-hero-clean .tools-quick-summary { grid-template-columns: 1fr; }
    .tools-hero-clean .tools-quick-summary span { border-right: 0; border-bottom: 1px solid rgba(255, 255, 255, 0.13); }
    .tools-hero-clean .tools-quick-summary span:last-child { border-bottom: 0; }
  }
</style>


<section class="page-hero tools-hero tools-hero-clean">
  <div class="container">
    <div class="tools-hero-grid">
      <div class="tools-hero-copy">
        <span class="eyebrow">Tools Directory</span>
        <h1>Free tools for SEO, content, and campaign work.</h1>
        <p>
          Browser-based tools for tracking links, reviewing content, creating metadata, measuring campaigns, and finishing everyday marketing tasks.
        </p>
        <div class="tools-hero-actions">
          <a class="btn btn-primary" href="/tools/utm-builder/">Open UTM Builder</a>
          <a class="btn btn-secondary" href="#all-tools">Browse All Tools</a>
        </div>
      </div>

      <aside class="tools-quick-panel" aria-label="Popular marketing tools">
        <div class="tools-quick-head">
          <strong>Quick access</strong>
          <span>Popular marketing workflows</span>
        </div>
        <div class="tools-quick-list">
          <a class="tools-quick-item" href="/tools/utm-builder/">
            <span><strong>UTM Builder</strong><small>Build campaign tracking links</small></span>
            <em>Open</em>
          </a>
          <a class="tools-quick-item" href="/tools/keyword-density-checker/">
            <span><strong>Keyword Density Checker</strong><small>Review repeated SEO terms</small></span>
            <em>Open</em>
          </a>
          <a class="tools-quick-item" href="/tools/serp-snippet-preview/">
            <span><strong>SERP Snippet Preview</strong><small>Preview Google search results</small></span>
            <em>Open</em>
          </a>
        </div>
        <div class="tools-quick-summary">
          <span>{{ tools | length }} tools</span>
          <span>{{ articles | length }} guides</span>
          <span>No signup</span>
        </div>
      </aside>
    </div>
  </div>
</section>

<section id="all-tools" class="section tools-directory-section">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">All Tools</span>
      <h2 class="section-title">Choose the job you need to finish.</h2>
      <p class="section-desc">
        Each tool has a focused interface, a clean URL, and supporting guidance so visitors can act quickly.
      </p>
    </div>

    <div class="feature-grid">
      {% for tool in tools %}
        <article class="feature-card lift">
          <div class="feature-top">
            <span class="feature-tag">{{ tool.category }}</span>
            <span class="status-dot">{{ "Core" if tool.featured else "Utility" }}</span>
          </div>
          <div class="feature-body">
            <h3>{{ tool.name }}</h3>
            <p>{{ tool.description }}</p>
          </div>
          <div class="feature-bottom">
            <span class="feature-meta">Free to use</span>
            <a href="{{ tool.url }}" class="btn btn-primary btn-sm">{{ tool.cta }}</a>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

