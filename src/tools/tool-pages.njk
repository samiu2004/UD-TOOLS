---
layout: base.njk
pagination:
  data: tools
  size: 1
  alias: tool
permalink: "/tools/{{ tool.slug }}/"
eleventyComputed:
  title: "{{ tool.seoTitle or tool.name }}"
  description: "{{ tool.description }}"
---

<section class="page-hero">
  <div class="container">
    <div class="tool-hero">
      <div>
        <span class="eyebrow">{{ tool.category }}</span>
        <h1>{{ tool.name }}</h1>
        <p class="page-hero-lead">
          {{ tool.description }}
        </p>
      </div>
      <div class="tool-hero-note">
        <strong>Free to use</strong>
        <span>No account required. Built for quick browser workflows.</span>
      </div>
    </div>
  </div>
</section>

<section class="section-tight">
  <div class="container">
    <div class="page-grid">
      <div>
        <div class="tool-panel">
          <h2>Use this tool</h2>
          <p class="muted">
            Enter your inputs below and the results will update in the browser.
          </p>

          {% if tool.slug == "word-counter" %}
            <div class="form-group">
              <label for="textInput">Your text</label>
              <textarea id="textInput" class="tool-input" placeholder="Paste your text here..."></textarea>
            </div>

            <div class="hero-actions" style="margin-bottom:0;">
              <button id="clearBtn" class="btn btn-secondary" type="button">Clear Text</button>
              <button id="sampleBtn" class="btn btn-primary" type="button">Load Example</button>
            </div>

            <div class="results-grid">
              <div class="result-box">
                <strong id="wordCount">0</strong>
                <span>Words</span>
              </div>
              <div class="result-box">
                <strong id="charCount">0</strong>
                <span>Characters</span>
              </div>
              <div class="result-box">
                <strong id="charNoSpaceCount">0</strong>
                <span>Characters without spaces</span>
              </div>
              <div class="result-box">
                <strong id="sentenceCount">0</strong>
                <span>Sentences</span>
              </div>
              <div class="result-box">
                <strong id="paragraphCount">0</strong>
                <span>Paragraphs</span>
              </div>
              <div class="result-box">
                <strong id="readingTime">0 min</strong>
                <span>Reading time</span>
              </div>
              <div class="result-box">
                <strong id="speakingTime">0 min</strong>
                <span>Speaking time</span>
              </div>
              <div class="result-box">
                <strong id="avgWordsPerSentence">0</strong>
                <span>Avg. words / sentence</span>
              </div>
            </div>

          {% elif tool.slug == "keyword-density-checker" %}
            <div class="form-group">
              <label for="densityText">Your text</label>
              <textarea id="densityText" class="tool-input" placeholder="Paste your article, blog post, or landing page copy here..."></textarea>
            </div>

            <div class="hero-actions" style="margin-bottom:0;">
              <button id="densityClearBtn" class="btn btn-secondary" type="button">Clear Text</button>
              <button id="densitySampleBtn" class="btn btn-primary" type="button">Load Example</button>
            </div>

            <div class="results-grid">
              <div class="result-box">
                <strong id="densityWordCount">0</strong>
                <span>Total words</span>
              </div>
              <div class="result-box">
                <strong id="densityUniqueCount">0</strong>
                <span>Unique words</span>
              </div>
              <div class="result-box">
                <strong id="densityTopKeyword">-</strong>
                <span>Top keyword</span>
              </div>
              <div class="result-box">
                <strong id="densityTopPercent">0%</strong>
                <span>Top keyword density</span>
              </div>
            </div>

            <div class="content-card" style="margin-top:24px;">
              <h3>Top keyword usage</h3>
              <div id="densityResults">
                <p class="muted">Keyword results will appear here after you enter text.</p>
              </div>
            </div>

          {% elif tool.slug == "readability-checker" %}
            <div class="form-group">
              <label for="readabilityText">Your text</label>
              <textarea id="readabilityText" class="tool-input" placeholder="Paste your article, email, blog post, or landing page text here..."></textarea>
            </div>

            <div class="hero-actions" style="margin-bottom:0;">
              <button id="readabilityClearBtn" class="btn btn-secondary" type="button">Clear Text</button>
              <button id="readabilitySampleBtn" class="btn btn-primary" type="button">Load Example</button>
            </div>

            <div class="results-grid">
              <div class="result-box">
                <strong id="readabilityWords">0</strong>
                <span>Words</span>
              </div>
              <div class="result-box">
                <strong id="readabilitySentences">0</strong>
                <span>Sentences</span>
              </div>
              <div class="result-box">
                <strong id="readabilitySyllables">0</strong>
                <span>Syllables</span>
              </div>
              <div class="result-box">
                <strong id="fleschScore">0</strong>
                <span>Flesch Reading Ease</span>
              </div>
              <div class="result-box">
                <strong id="gradeLevel">0</strong>
                <span>Flesch-Kincaid Grade</span>
              </div>
              <div class="result-box">
                <strong id="readingLevelLabel">-</strong>
                <span>Reading level</span>
              </div>
            </div>

            <div class="content-card" style="margin-top:24px;">
              <h3>Readability summary</h3>
              <div id="readabilitySummary">
                <p class="muted">Readability guidance will appear here after you enter text.</p>
              </div>
            </div>

          {% elif tool.slug == "meta-tag-generator" %}
            <div class="form-group">
              <label for="metaTitle">Page title</label>
              <input id="metaTitle" class="tool-input" type="text" placeholder="Example: Free Keyword Density Checker for SEO Content">
            </div>

            <div class="form-group">
              <label for="metaDescription">Meta description</label>
              <textarea id="metaDescription" class="tool-input" placeholder="Write a concise page description for search results and social previews..."></textarea>
            </div>

            <div class="form-group">
              <label for="metaCanonical">Canonical URL</label>
              <input id="metaCanonical" class="tool-input" type="url" placeholder="https://example.com/page/">
            </div>

            <div class="form-group">
              <label for="metaRobots">Robots</label>
              <input id="metaRobots" class="tool-input" type="text" value="index, follow" placeholder="index, follow">
            </div>

            <div class="form-group">
              <label for="metaOgImage">Open Graph / Twitter image URL</label>
              <input id="metaOgImage" class="tool-input" type="url" placeholder="https://example.com/og-image.jpg">
            </div>

            <div class="hero-actions" style="margin-bottom:0;">
              <button id="metaClearBtn" class="btn btn-secondary" type="button">Clear</button>
              <button id="metaSampleBtn" class="btn btn-primary" type="button">Load Example</button>
            </div>

            <div class="results-grid">
              <div class="result-box">
                <strong id="metaTitleCount">0</strong>
                <span>Title length</span>
              </div>
              <div class="result-box">
                <strong id="metaDescriptionCount">0</strong>
                <span>Description length</span>
              </div>
              <div class="result-box">
                <strong id="metaCanonicalStatus">-</strong>
                <span>Canonical</span>
              </div>
              <div class="result-box">
                <strong id="metaImageStatus">-</strong>
                <span>Image</span>
              </div>
            </div>

            <div class="content-card" style="margin-top:24px;">
              <h3>Generated meta tags</h3>
              <textarea id="metaOutput" class="tool-input" rows="14" readonly placeholder="Your generated meta tags will appear here..."></textarea>
            </div>

            <div class="content-card" style="margin-top:24px;">
              <h3>Tag guidance</h3>
              <div id="metaTips">
                <p class="muted">Guidance will appear here as you fill in the fields.</p>
              </div>
            </div>

          {% elif tool.slug == "cpc-roas-calculator" %}
            <div class="form-group">
              <label for="adSpend">Ad spend</label>
              <input id="adSpend" class="tool-input" type="number" min="0" step="0.01" placeholder="1000">
            </div>

            <div class="form-group">
              <label for="clicks">Clicks</label>
              <input id="clicks" class="tool-input" type="number" min="0" step="1" placeholder="500">
            </div>

            <div class="form-group">
              <label for="conversions">Conversions</label>
              <input id="conversions" class="tool-input" type="number" min="0" step="1" placeholder="25">
            </div>

            <div class="form-group">
              <label for="revenue">Revenue from ads</label>
              <input id="revenue" class="tool-input" type="number" min="0" step="0.01" placeholder="4000">
            </div>

            <div class="hero-actions" style="margin-bottom:0;">
              <button id="cpcClearBtn" class="btn btn-secondary" type="button">Clear</button>
              <button id="cpcSampleBtn" class="btn btn-primary" type="button">Load Example</button>
            </div>

            <div class="results-grid">
              <div class="result-box">
                <strong id="calcCpc">0.00</strong>
                <span>CPC</span>
              </div>
              <div class="result-box">
                <strong id="calcCpa">0.00</strong>
                <span>CPA</span>
              </div>
              <div class="result-box">
                <strong id="calcConvRate">0%</strong>
                <span>Conversion rate</span>
              </div>
              <div class="result-box">
                <strong id="calcRoas">0x</strong>
                <span>ROAS</span>
              </div>
              <div class="result-box">
                <strong id="calcRoasPercent">0%</strong>
                <span>ROAS %</span>
              </div>
              <div class="result-box">
                <strong id="calcProfit">0.00</strong>
                <span>Revenue minus spend</span>
              </div>
            </div>

            <div class="content-card" style="margin-top:24px;">
              <h3>Performance summary</h3>
              <div id="cpcSummary">
                <p class="muted">Campaign guidance will appear here as you fill in the fields.</p>
              </div>
            </div>

          {% elif tool.slug == "utm-builder" %}
            <div class="form-group">
              <label for="campaignBaseUrl">Website URL</label>
              <input id="campaignBaseUrl" class="tool-input" type="url" placeholder="https://example.com/landing-page/">
            </div>

            <div class="form-group">
              <label for="utmSource">Campaign source</label>
              <input id="utmSource" class="tool-input" type="text" placeholder="google, newsletter, linkedin">
            </div>

            <div class="form-group">
              <label for="utmMedium">Campaign medium</label>
              <input id="utmMedium" class="tool-input" type="text" placeholder="cpc, email, social">
            </div>

            <div class="form-group">
              <label for="utmCampaign">Campaign name</label>
              <input id="utmCampaign" class="tool-input" type="text" placeholder="summer-sale, product-launch">
            </div>

            <div class="form-group">
              <label for="utmContent">Campaign content (optional)</label>
              <input id="utmContent" class="tool-input" type="text" placeholder="button-a, banner-top">
            </div>

            <div class="form-group">
              <label for="utmTerm">Campaign term (optional)</label>
              <input id="utmTerm" class="tool-input" type="text" placeholder="seo-tool, paid-keyword">
            </div>

            <div class="hero-actions" style="margin-bottom:0;">
              <button id="campaignClearBtn" class="btn btn-secondary" type="button">Clear</button>
              <button id="campaignSampleBtn" class="btn btn-primary" type="button">Load Example</button>
            </div>

            <div class="results-grid">
              <div class="result-box">
                <strong id="campaignUrlStatus">-</strong>
                <span>Base URL</span>
              </div>
              <div class="result-box">
                <strong id="campaignRequiredStatus">-</strong>
                <span>Required fields</span>
              </div>
              <div class="result-box">
                <strong id="campaignLength">0</strong>
                <span>URL length</span>
              </div>
              <div class="result-box">
                <strong id="campaignParamCount">0</strong>
                <span>UTM fields used</span>
              </div>
            </div>

            <div class="content-card" style="margin-top:24px;">
              <h3>Generated campaign URL</h3>
              <textarea id="campaignOutput" class="tool-input" rows="6" readonly placeholder="Your campaign URL will appear here..."></textarea>
            </div>

            <div class="content-card" style="margin-top:24px;">
              <h3>Tracking guidance</h3>
              <div id="campaignTips">
                <p class="muted">Tracking guidance will appear here as you fill in the fields.</p>
              </div>
            </div>

          {% elif tool.slug == "qr-code-generator" %}
            <div class="form-group">
              <label for="qrContent">Content to encode</label>
              <textarea id="qrContent" class="tool-input" placeholder="Enter a URL, message, phone number, email, or campaign link..."></textarea>
            </div>

            <div class="form-group">
              <label for="qrSize">QR size</label>
              <select id="qrSize" class="tool-input">
                <option value="200">200 x 200</option>
                <option value="300" selected>300 x 300</option>
                <option value="400">400 x 400</option>
                <option value="600">600 x 600</option>
              </select>
            </div>

            <div class="form-group">
              <label for="qrErrorLevel">Error correction</label>
              <select id="qrErrorLevel" class="tool-input">
                <option value="L">Low (7%)</option>
                <option value="M" selected>Medium (15%)</option>
                <option value="Q">Quartile (25%)</option>
                <option value="H">High (30%)</option>
              </select>
            </div>

            <div class="form-group">
              <label for="qrMargin">Quiet zone / margin</label>
              <select id="qrMargin" class="tool-input">
                <option value="1">1 module</option>
                <option value="2">2 modules</option>
                <option value="4" selected>4 modules</option>
                <option value="8">8 modules</option>
              </select>
            </div>

            <div class="hero-actions" style="margin-bottom:0;">
              <button id="qrClearBtn" class="btn btn-secondary" type="button">Clear</button>
              <button id="qrSampleBtn" class="btn btn-primary" type="button">Load Example</button>
            </div>

            <div class="results-grid">
              <div class="result-box">
                <strong id="qrContentStatus">-</strong>
                <span>Content</span>
              </div>
              <div class="result-box">
                <strong id="qrSelectedSize">300</strong>
                <span>Size</span>
              </div>
              <div class="result-box">
                <strong id="qrSelectedLevel">M</strong>
                <span>Error correction</span>
              </div>
              <div class="result-box">
                <strong id="qrSelectedMargin">4</strong>
                <span>Margin</span>
              </div>
            </div>

            <div class="content-card" style="margin-top:24px;">
              <h3>Generated QR code</h3>
              <div id="qrPreview" class="preview-box" style="min-height:320px;">
                <p class="muted">Your QR code preview will appear here.</p>
              </div>
            </div>

            <div class="hero-actions" style="margin-top:24px; margin-bottom:0;">
              <button id="qrDownloadPngBtn" class="btn btn-primary" type="button">Download PNG</button>
              <button id="qrDownloadSvgBtn" class="btn btn-secondary" type="button">Download SVG</button>
            </div>

            <div class="content-card" style="margin-top:24px;">
              <h3>QR guidance</h3>
              <div id="qrTips">
                <p class="muted">QR best-practice guidance will appear here as you fill in the fields.</p>
              </div>
            </div>

          {% elif tool.slug == "qr-barcode-scanner" %}
            <div class="hero-actions" style="margin-bottom:24px;">
              <button id="scannerStartBtn" class="btn btn-primary" type="button">Start Camera</button>
              <button id="scannerStopBtn" class="btn btn-secondary" type="button">Stop Camera</button>
            </div>

            <div class="form-group">
              <label for="scannerFileInput">Upload image (QR or barcode)</label>
              <input id="scannerFileInput" class="tool-input" type="file" accept="image/*">
            </div>

            <div class="results-grid">
              <div class="result-box">
                <strong id="scannerSupportStatus">Checking…</strong>
                <span>Browser support</span>
              </div>
              <div class="result-box">
                <strong id="scannerCameraStatus">Idle</strong>
                <span>Camera</span>
              </div>
              <div class="result-box">
                <strong id="scannerDetectedFormat">-</strong>
                <span>Format</span>
              </div>
              <div class="result-box">
                <strong id="scannerDetectionMode">-</strong>
                <span>Detection mode</span>
              </div>
            </div>

            <div class="content-card" style="margin-top:24px;">
              <h3>Live scanner</h3>
              <div style="position:relative; overflow:hidden; border-radius:16px; background:#000;">
                <video id="scannerVideo" playsinline muted style="width:100%; min-height:280px; background:#000;"></video>
              </div>
              <p class="muted" style="margin-top:12px;">Point your camera at a QR code or supported barcode once scanning starts.</p>
            </div>

            <div class="content-card" style="margin-top:24px;">
              <h3>Uploaded image preview</h3>
              <div id="scannerImagePreview" class="preview-box" style="min-height:220px;">
                <p class="muted">Upload an image to scan a QR code or barcode without using the camera.</p>
              </div>
            </div>

            <div class="content-card" style="margin-top:24px;">
              <h3>Decoded result</h3>
              <textarea id="scannerResult" class="tool-input" rows="6" readonly placeholder="Scanned content will appear here..."></textarea>
            </div>

            <div class="content-card" style="margin-top:24px;">
              <h3>Scanner guidance</h3>
              <div id="scannerTips">
                <p class="muted">Scanner tips and support notes will appear here.</p>
              </div>
            </div>

          {% else %}
            <div class="content-card">
              <p>
                The dedicated interface for {{ tool.name }} will be added in the next migration step.
              </p>
            </div>
          {% endif %}
        </div>

        <div class="content-card" style="margin-top:24px;">
          <h2>About this tool</h2>
          <p>
            {{ tool.description }}
          </p>
        </div>
        {% if tool.guide %}
          <section class="content-card tool-guide" style="margin-top:24px;">
            <div class="section-head">
              <span class="eyebrow">{{ tool.guide.eyebrow }}</span>
              <h2>{{ tool.guide.title }}</h2>
              {% for paragraph in tool.guide.intro %}
                <p class="section-desc">{{ paragraph }}</p>
              {% endfor %}
            </div>

            <div class="guide-block">
              <h3>{{ tool.guide.stepsTitle }}</h3>
              <div class="guide-steps">
                {% for step in tool.guide.steps %}
                  <div class="guide-step">
                    <strong>{{ loop.index }}. {{ step.title }}</strong>
                    <p>{{ step.text }}</p>
                  </div>
                {% endfor %}
              </div>
            </div>

            <div class="guide-block">
              <h3>{{ tool.guide.exampleTitle }}</h3>
              <p class="muted">{{ tool.guide.exampleIntro }}</p>
              <dl class="example-list">
                {% for item in tool.guide.example %}
                  <div>
                    <dt>{{ item.label }}</dt>
                    <dd>{{ item.value }}</dd>
                  </div>
                {% endfor %}
              </dl>
            </div>

            <div class="guide-block">
              <h3>{{ tool.guide.bestPracticesTitle }}</h3>
              <ul class="check-list">
                {% for item in tool.guide.bestPractices %}
                  <li>{{ item }}</li>
                {% endfor %}
              </ul>
            </div>

            {% if tool.relatedArticles %}
              <div class="guide-block guide-related">
                <h3>{{ tool.guide.relatedTitle }}</h3>
                <p class="muted">{{ tool.guide.relatedText }}</p>
                <div class="related-link-grid">
                  {% for slug in tool.relatedArticles %}
                    {% for article in articles %}
                      {% if article.slug == slug %}
                        <a href="/articles/{{ article.slug }}/">{{ article.title }}</a>
                      {% endif %}
                    {% endfor %}
                  {% endfor %}
                </div>
              </div>
            {% endif %}
          </section>
        {% endif %}



        {% if tool.faq %}
          <section class="content-card faq-section" style="margin-top:24px;">
            <div class="section-head">
              <span class="eyebrow">FAQ</span>
              <h2>Frequently asked questions</h2>
              <p class="section-desc">Quick answers for visitors using {{ tool.name }}.</p>
            </div>

            <div class="faq-list">
              {% for item in tool.faq %}
                <details class="faq-item">
                  <summary>{{ item.question }}</summary>
                  <p>{{ item.answer }}</p>
                </details>
              {% endfor %}
            </div>
          </section>
        {% endif %}
      </div>

      <aside>
        <div class="sidebar-card">
          <h3>Related tools</h3>
          <ul class="list-clean">
            {% for item in tools %}
              {% if item.slug != tool.slug and item.featured %}
                <li><a class="mini-link" href="{{ item.url }}">{{ item.name }}</a></li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>

        {% if tool.relatedArticles %}
          <div class="sidebar-card" style="margin-top:24px;">
            <h3>Related guides</h3>
            <ul class="list-clean">
              {% for slug in tool.relatedArticles %}
                {% for article in articles %}
                  {% if article.slug == slug %}
                    <li><a class="mini-link" href="/articles/{{ article.slug }}/">{{ article.title }}</a></li>
                  {% endif %}
                {% endfor %}
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      </aside>
    </div>
  </div>
</section>

{% if tool.slug == "word-counter" %}
  <script src="/assets/js/word-counter.js"></script>
{% elif tool.slug == "keyword-density-checker" %}
  <script src="/assets/js/keyword-density.js"></script>
{% elif tool.slug == "readability-checker" %}
  <script src="/assets/js/readability-checker.js"></script>
{% elif tool.slug == "meta-tag-generator" %}
  <script src="/assets/js/meta-tag-generator.js"></script>
{% elif tool.slug == "cpc-roas-calculator" %}
  <script src="/assets/js/cpc-roas-calculator.js"></script>
{% elif tool.slug == "utm-builder" %}
  <script src="/assets/js/campaign-url-builder.js"></script>
{% elif tool.slug == "qr-code-generator" %}
  <script src="/assets/js/qr-code-generator.js"></script>
{% elif tool.slug == "qr-barcode-scanner" %}
  <script src="https://unpkg.com/jsqr/dist/jsQR.js"></script>
  <script src="/assets/js/qr-barcode-scanner.js"></script>
{% endif %}

{% if tool.faq %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in tool.faq %}
    {
      "@type": "Question",
      "name": "{{ item.question }}",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ item.answer }}"
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}
