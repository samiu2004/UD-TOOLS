<!-- Hero -->
<section class="page-hero">
  <div class="container">
    <span class="eyebrow">About UD Tools</span>
    <h1>Free tools that respect your time and your data.</h1>
    <p>
      UD Tools is a growing collection of free, browser-based tools built for writers,
      marketers, and creators who need fast answers without sign-ups, paywalls, or
      privacy trade-offs.
    </p>
  </div>
</section>

<!-- Stats row -->
<section class="section-tight">
  <div class="container">
    <div class="results-grid">
      <div class="result-box">
        <strong>{{ tools | length }}</strong>
        <span>Free tools</span>
      </div>
      <div class="result-box">
        <strong>0</strong>
        <span>Sign-ups required</span>
      </div>
      <div class="result-box">
        <strong>100%</strong>
        <span>Runs in your browser</span>
      </div>
      <div class="result-box">
        <strong>0</strong>
        <span>Data sent to servers</span>
      </div>
    </div>
  </div>
</section>

<!-- Mission -->
<section class="section-tight">
  <div class="container">
    <div class="page-grid">
      <div>
        <div class="content-card">
          <h2>Why we built this</h2>
          <p>
            Most online tools come with a catch: a sign-up wall, a usage limit, or
            aggressive upselling after three free uses. UD Tools started as a
            frustration with exactly that. Every tool here is fully free, processes
            everything in your browser, and never touches your content on a server.
          </p>
          <p>
            The mission is simple: one focused, well-built tool for each task that
            marketers and writers repeat every day: word counting, keyword checking,
            readability scoring, UTM building, and QR generating, done properly without noise.
          </p>
        </div>

        <div class="content-card" style="margin-top:24px;">
          <h2>What sets us apart</h2>
          <div class="results-grid" style="margin-top:16px;">
            <div class="result-box">
              <strong>Private by design</strong>
              <span>Your text never leaves your device. All processing is local, in-browser.</span>
            </div>
            <div class="result-box">
              <strong>No account walls</strong>
              <span>Open a tool, use it, leave. No email, no password, no cookie consent flows.</span>
            </div>
            <div class="result-box">
              <strong>Built for speed</strong>
              <span>Every tool gives you a result in under a second. No loading spinners.</span>
            </div>
            <div class="result-box">
              <strong>Always free</strong>
              <span>No freemium tier. No premium plan. Free means free.</span>
            </div>
          </div>
        </div>

        <div class="content-card" style="margin-top:24px;">
          <h2>What's coming next</h2>
          <p>
            UD Tools is actively expanding. The next tools in development focus on
            content readability improvement suggestions, bulk UTM generation from CSV,
            and an OG image preview checker. Every tool follows the same rule: fast,
            free, and private.
          </p>
          <div class="hero-actions" style="margin-top:24px; margin-bottom:0;">
            <a href="/tools/" class="btn btn-primary">Explore all tools</a>
          </div>
        </div>
      </div>

      <aside>
        <div class="sidebar-card">
          <h3>All tools</h3>
          <ul class="list-clean">
            {% for tool in tools %}
            <li><a class="mini-link" href="{{ tool.url }}">{{ tool.name }}</a></li>
            {% endfor %}
          </ul>
        </div>

        <div class="sidebar-card" style="margin-top:24px;">
          <h3>Built on principles</h3>
          <ul class="list-clean">
            <li class="muted" style="font-size:var(--text-sm); padding:4px 0;">No data collection</li>
            <li class="muted" style="font-size:var(--text-sm); padding:4px 0;">Instant results</li>
            <li class="muted" style="font-size:var(--text-sm); padding:4px 0;">No login required</li>
            <li class="muted" style="font-size:var(--text-sm); padding:4px 0;">Works on mobile</li>
            <li class="muted" style="font-size:var(--text-sm); padding:4px 0;">Accessible design</li>
          </ul>
        </div>
      </aside>
    </div>
  </div>
</section>
